APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8888

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — use Brevo SMTP for transactional email in production
# Dashboard: SMTP & API → SMTP (use SMTP login + SMTP password/key, not the REST API key)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@shipmater.com"
MAIL_FROM_NAME="Shipmater"

# Frontend URL used in email verification links
FRONTEND_URL=http://localhost:3000

# Twilio (phone OTP). Without these, local/dev logs the OTP to the API log.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1XXXXXXXXXX
# TWILIO_VERIFY_SID=VAXXXXXXXX (preferred — Twilio Verify service)

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Production overrides (Railway) ──────────────────────────────────────
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://api.shipmater.com
#
# DB_CONNECTION=pgsql
# DB_HOST=              ← from Railway Postgres "Connect" tab
# DB_PORT=5432
# DB_DATABASE=railway
# DB_USERNAME=postgres
# DB_PASSWORD=          ← from Railway Postgres "Connect" tab
#
# SESSION_DRIVER=cookie
# SESSION_SECURE_COOKIE=true
#
# CORS — optional extra origins (production defaults are in config/cors.php)
# CORS_ALLOWED_ORIGINS=https://shipmater.netlify.app
#
# LOG_CHANNEL=stderr
# LOG_LEVEL=error
