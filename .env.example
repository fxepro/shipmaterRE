# Copy to .env.local — ports are pinned in package.json / api/composer.json
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Production (Netlify) — server-side proxy; client uses same-origin /api/*
# API_PROXY_URL=https://shipmater.up.railway.app
# (Do NOT rely on NEXT_PUBLIC_API_URL alone — it is baked in at build time.)
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_MAPTILER_KEY=
NEXT_PUBLIC_STRIPE_PK=
# Hostname shown in the custom-domain CNAME hint on the white-label branding page
NEXT_PUBLIC_APP_HOST=app.shipmater.com
